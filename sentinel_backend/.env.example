PROJECT_NAME="SentinelAI API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Security — REQUIRED in production (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_secret_key_here

# CORS — optional: if your frontend URL differs from the hardcoded list, add it here
FRONTEND_URL=https://your-custom-frontend.vercel.app

# Feature Flags
ENABLE_GRAPH_EVIDENCE_ENGINE=true

# Google Auth
GOOGLE_CLIENT_ID=415088459995-tq690mnheb7v06t25sgf8i8brfamndm4.apps.googleusercontent.com

# PostgreSQL
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sanjay
POSTGRES_DB=sentinel
POSTGRES_PORT=5433

DATABASE_URL=postgresql://<user>:<password>@<host>/<database>

# Neo4j
NEO4J_URI=neo4j+s://<your-instance>.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Redis
# Connection URL (use rediss:// for SSL/TLS connections, e.g. Upstash)
REDIS_URL=redis://localhost:6379

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

